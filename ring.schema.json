{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ring.pickles.dev/ring.schema.json",
  "title": "Dead HTML Tag Society ring",
  "description": "Schema for ring.json, the source of truth for webring membership.",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "url", "members"],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "pattern": "^[^<>&\"'\\u0000-\\u001f\\u007f-\\u009f\\u200e\\u200f\\u202a-\\u202e\\u2066-\\u2069]*$"
    },
    "url": {
      "type": "string",
      "format": "uri",
      "pattern": "^https://"
    },
    "members": {
      "type": "array",
      "items": { "$ref": "#/definitions/member" },
      "uniqueItems": false
    }
  },
  "definitions": {
    "member": {
      "type": "object",
      "additionalProperties": false,
      "required": ["slug", "name", "url", "owner", "tag", "joined"],
      "properties": {
        "slug": {
          "type": "string",
          "pattern": "^[a-z0-9-]{1,32}$"
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100,
          "pattern": "^[^<>&\"'\\u0000-\\u001f\\u007f-\\u009f\\u200e\\u200f\\u202a-\\u202e\\u2066-\\u2069]*$"
        },
        "url": {
          "type": "string",
          "format": "uri",
          "pattern": "^https://"
        },
        "owner": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100,
          "pattern": "^[^<>&\"'\\u0000-\\u001f\\u007f-\\u009f\\u200e\\u200f\\u202a-\\u202e\\u2066-\\u2069]*$"
        },
        "tag": {
          "type": "string",
          "pattern": "^[a-z0-9]{1,32}$"
        },
        "badge": {
          "type": "string",
          "pattern": "^badges/[a-z0-9-]{1,32}\\.(png|gif)$"
        },
        "rss": {
          "type": "string",
          "format": "uri",
          "pattern": "^https://"
        },
        "joined": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$",
          "format": "date"
        }
      }
    }
  }
}
